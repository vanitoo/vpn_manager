BOT_TOKEN=123456:CHANGE_ME
ADMIN_IDS=123456789
DB_PATH=data/bot.sqlite3

# Демо-развертывание: при пустой базе добавляет тестовые «Книга 1» — «Книга 4».
# Для рабочего магазина после настройки можно поставить false.
SEED_BOOKS_ON_START=true

# Если у бота раньше был webhook, polling не заработает без deleteWebhook.
DELETE_WEBHOOK_ON_START=true
DROP_PENDING_UPDATES=false

# Прокси:
# off      — без прокси
# single   — только первый прокси, без переключения
# sticky   — держим один живой прокси, переключаемся только при ошибке
# failover — primary -> backup; health-check возвращает на primary
# random   — случайный живой прокси при выборе
# rotate   — следующий живой прокси при каждом выборе
PROXY_MODE=off

# Можно через запятую, точку с запятой или переносы строк.
# PROXY=http://user:pass@host:3128,http://user:pass@host:3129;socks5://user:pass@host:1080
PROXY=

PROXY_HEALTHCHECK_URL=https://api.telegram.org
PROXY_HEALTHCHECK_TIMEOUT=8
PROXY_HEALTHCHECK_INTERVAL=60

# Цена в рублях пересчитывается в Stars по формуле:
# stars = ceil(price_rub / STARS_RUB_PER_STAR)
STARS_RUB_PER_STAR=1.70

# Оплаты
# Можно включать несколько способов через запятую:
# PAYMENT_PROVIDERS=stars,yookassa
# Доступно: stars, yookassa, lava, platega
PAYMENT_PROVIDERS=stars

# Старый/альтернативный вариант флагами тоже поддерживается:
ENABLE_STARS=true
YOOKASSA_ENABLED=false
LAVA_ENABLED=false
PLATEGA_ENABLED=false

# ЮKassa. Работает без webhook: бот создает ссылку оплаты,
# пользователь платит и нажимает кнопку «Я оплатил», бот проверяет статус по API.
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Если пусто, return_url будет https://t.me/<bot>?start=book_<slug>
YOOKASSA_RETURN_URL=
YOOKASSA_TEST_MODE=true

# Чеки для внешних платежек.
# true  - спросить у покупателя email или телефон и сохранить.
# false - использовать резервный email, удобно для тестов.
RECEIPT_REQUIRE_CONTACT=true
RECEIPT_FALLBACK_EMAIL=orders@example.com
RECEIPT_SAVE_CONTACT=true

# Lava / Platega пока подключены как отдельные модули-заглушки.
# После проверки актуального API добавляются без переделки магазина.
LAVA_SHOP_ID=
LAVA_API_KEY=
LAVA_SECRET_KEY=

PLATEGA_MERCHANT_ID=
PLATEGA_API_KEY=


# Логи
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# Автоматически регистрировать команды Telegram и включать кнопку меню при старте.
# Полезно после переноса бота на новый токен/аккаунт BotFather.
AUTO_SETUP_BOT_MENU=true

# Обложки книг.
# Админ может отправить JPG/PNG/WEBP, бот сам сделает cover.jpg и cover_small.jpg.
COVER_WIDTH=1200
COVER_HEIGHT=1800
COVER_QUALITY=90
GENERATE_COVER_THUMBNAIL=true
COVER_THUMB_WIDTH=400
COVER_THUMB_HEIGHT=600
COVER_MIN_WIDTH=600
COVER_MIN_HEIGHT=900

# Pending external payments
# Сколько минут показывать кнопку «Проверить оплату» для незавершенного платежа.
PENDING_PAYMENT_TTL_MINUTES=60

# Уведомления админам о новых покупках.
# true  - админы из ADMIN_IDS получают сообщение о каждой покупке.
# false - покупки только в логах/статистике.
ADMIN_NOTIFY_PURCHASES=true
