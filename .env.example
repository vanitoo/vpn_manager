# Telegram
BOT_TOKEN=123456:CHANGE_ME
ADMIN_IDS=123456789
DB_PATH=data/vpn_bot.sqlite3

# При первом запуске создаёт демо-тарифы на 30 и 90 дней.
SEED_PLANS_ON_START=true

# Local polling mode. No server, domain or incoming webhook is required.
DELETE_WEBHOOK_ON_START=true
DROP_PENDING_UPDATES=false
AUTO_SETUP_BOT_MENU=true

# Optional proxy for Telegram Bot API
PROXY_MODE=off
PROXY=
PROXY_HEALTHCHECK_URL=https://api.telegram.org
PROXY_HEALTHCHECK_TIMEOUT=8
PROXY_HEALTHCHECK_INTERVAL=60

# Payments
# Possible: stars,yookassa,cryptomus,lava,platega
PAYMENT_PROVIDERS=stars
ENABLE_STARS=true
YOOKASSA_ENABLED=false
CRYPTOMUS_ENABLED=false

# Stars conversion: stars = ceil(price_rub / STARS_RUB_PER_STAR)
STARS_RUB_PER_STAR=1.70

# YooKassa. No webhook: user opens URL and presses "Я оплатил".
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=https://t.me
YOOKASSA_TEST_MODE=true

# Cryptomus. No webhook: payment status is requested through API.
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=
CRYPTOMUS_CURRENCY=RUB
CRYPTOMUS_RETURN_URL=https://t.me

# Receipt contact settings for YooKassa.
RECEIPT_REQUIRE_CONTACT=false
RECEIPT_FALLBACK_EMAIL=orders@example.com
RECEIPT_SAVE_CONTACT=true
PENDING_PAYMENT_TTL_MINUTES=60

# Remnawave
REMNAWAVE_BASE_URL=
REMNAWAVE_API_TOKEN=
# Can be empty: bot will try to auto-discover internal squad.
REMNAWAVE_INTERNAL_SQUAD_UUID=
REMNAWAVE_EXTERNAL_SQUAD_UUID=
REMNAWAVE_SUBSCRIPTION_BASE_URL=https://ss.6679.ru
# 0 means unlimited.
REMNAWAVE_DEFAULT_TRAFFIC_GB=0
# 0 means no HWID limit field is sent.
REMNAWAVE_HWID_DEVICE_LIMIT=0

# If Remnawave panel is protected by nginx cookie/basic auth.
REMNAWAVE_NGINX_AUTH_ENABLED=false
REMNAWAVE_NGINX_COOKIE_NAME=
REMNAWAVE_NGINX_COOKIE_VALUE=
REMNAWAVE_NGINX_BASIC_LOGIN=
REMNAWAVE_NGINX_BASIC_PASSWORD=

# Lifecycle alerts to ADMIN_IDS
STARTUP_ALERTS_ENABLED=true
SHUTDOWN_ALERTS_ENABLED=true
ADMIN_NOTIFY_PURCHASES=true

# Local backups. Admin command: /backup
BACKUPS_ENABLED=true
BACKUP_DIR=backups

# Logs
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
